# The database url used by BetterAuth and Drizzle
DATABASE_URL=postgres://postgres:postgres@localhost:5439/main

# Vercel's Blob Storage read/write token
# Can be found in the Vercel dashboard under Settings > Storage
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_<key>"

# Posthog configuration
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# The better auth configuration (see: https://www.better-auth.com/docs/installation#set-environment-variables)
BETTER_AUTH_SECRET=FGHZDCnIW3IaYbQUY04YrVrUh1JuBQr2
BETTER_AUTH_URL=http://localhost:3000

# The app public url
NEXT_PUBLIC_APP_URL=http://localhost:3000

# The resend configuration
RESEND_FROM_EMAIL="PROJECT_NAME <no-reply@<PROJECT_NAME>.com>"
RESEND_API_KEY=re_xxxxx
